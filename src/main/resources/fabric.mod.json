{
	"schemaVersion": 1,
	"id": "anciencity",
	"version": "${version}",
	"name": "Ancient City Underground",
	"description": "Makes Ancient Cities generate densely underground in all Overworld biomes. Every chunk covered, safe spawn inside city, bedrock roof at Y=60 with no blocks/mobs above.",
	"authors": [
		"xiaomaiya"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/anciencity/image.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.example.TemplateMod"
		],
		"client": [
			"com.example.client.TemplateModClient"
		]
	},
	"mixins": [
		"anciencity.mixins.json",
		{
			"config": "anciencity.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}
